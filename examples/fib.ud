-- fib.ud -- recursion with typed functions.
-- `int function fib(int n)` declares both the return type and the parameter type.

int function fib(int n)
    if n < 2 then
        return n
    end
    return fib(n - 1) + fib(n - 2)
end

int function entry()
    for i = 0, 10 do
        cout("fib(" .. i .. ") = " .. fib(i))
    end
    return 0
end
