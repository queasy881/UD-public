{
    "comments": {
        "lineComment": "--"
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'", "close": "'", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*((int|float|bool|string)\\s+)?function\\b.*$|^\\s*struct\\b.*$|^\\s*else\\b.*$|\\b(then|do)\\s*(--.*|//.*)?$",
        "decreaseIndentPattern": "^\\s*(end|else|elseif|unless)\\b.*$"
    }
}
